{
  "name": "Python UV + CLI DevPod",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {},
  "customizations": {
    "devpod": {
      "prebuildRepository": "ghcr.io/v1xp/devpod.cli-uv"
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.gnupg,target=/home/vscode/.gnupg,type=bind,consistency=cached"
  ],
  "postCreateCommand": "uv --version",
  "remoteUser": "vscode"
}
